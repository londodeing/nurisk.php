{
  "type": "Container",
  "props": {
    "padding": [16, 16, 16, 16],
    "margin": [16, 8, 16, 8],
    "backgroundColor": "surface",
    "borderRadius": 16
  },
  "children": [
    {
      "type": "Column",
      "props": {
        "crossAxisAlignment": "start"
      },
      "children": [
        {
          "type": "Text",
          "props": {
            "text": "{{ title }}",
            "style": "title",
            "color": "text_main",
            "margin_bottom": 16
          }
        },
        {
          "type": "ListView",
          "props": {
            "shrinkWrap": true,
            "physics": "never",
            "padding": 0
          },
          "children": "{{ items }}"
        }
      ]
    }
  ]
}
