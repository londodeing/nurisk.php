# /etc/mysql/conf.d/nurisk.cnf
# sudo systemctl restart mariadb setelah perubahan
#
# Production config untuk MariaDB NURISK.
# Sesuaikan innodb_buffer_pool_size dengan RAM server (70% dari RAM).

[mysqld]

# Connections
max_connections         = 350
wait_timeout            = 600
interactive_timeout     = 600
connect_timeout         = 10

# InnoDB
innodb_buffer_pool_size = 2G
innodb_buffer_pool_instances = 2
innodb_flush_log_at_trx_commit = 2
innodb_log_file_size    = 512M
innodb_file_per_table   = 1
innodb_flush_method     = O_DIRECT

# Query cache — disabled (deprecated in MariaDB 10.4+)
query_cache_type = 0
query_cache_size = 0

# Logging
slow_query_log          = 1
slow_query_log_file     = /var/log/mysql/nurisk-slow.log
long_query_time         = 1

# Character set
character_set_server    = utf8mb4
collation_server        = utf8mb4_general_ci

# Binary log — untuk point-in-time recovery (aktifkan jika perlu)
# log_bin               = /var/log/mysql/mariadb-bin
# binlog_format         = ROW
# expire_logs_days      = 7
